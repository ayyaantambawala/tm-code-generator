  return rows.map((r,i)=>{
    const bt=r.boltType||"Stud Bolt",uw=parseFloat((r.unitWeight?parseFloat(r.unitWeight):calcW(bt,r.size,r.length,r.nuts,r.washers)).toFixed(3));
    const qty=parseFloat(r.qty)||1,tw=parseFloat((uw*qty).toFixed(3));
