    if(rateBase===null)return{sno:i+1,...r,unitWt:uw,totalWt:tw,qty,basePrice:0,coating:0,pricePerKg:0,unitAED:0,totalAED:0,compUnitAED:null,margin:null,finish,unavailable:true};
    const coat=getCoatPrice(finish,r.size,flat),ppkg=rateBase+coat;
