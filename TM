              ))}</tbody>
            </table>
          </div>
          <button onClick={()=>setWasherRates(WASHER_RATES_DEFAULT)} style={{marginTop:8,padding:"7px 18px",background:"rgba(239,68,68,0.1)",border:"1px solid rgba(239,68,68,0.2)",borderRadius:8,color:"#ef4444",fontSize:12,cursor:"pointer",fontWeight:600}}>Reset Washers</button>
        </div>}

        {/* ── GRADE PRICES ── */}
        {tab==="grades"&&<div style={s.card}>
          <p style={{fontSize:13,color:"#64748b",marginTop:0}}>Metal price per kg (AED) per grade.</p>
          {newGrades.length>0&&<div style={{marginBottom:16,padding:"12px 14px",background:"rgba(245,158,11,0.08)",border:"1px solid rgba(245,158,11,0.2)",borderRadius:10}}><p style={{margin:"0 0 6px",fontSize:12,color:"#f59e0b",fontWeight:600}}>New grades detected:</p>{newGrades.map(g=><span key={g} style={{display:"inline-block",margin:"2px 4px",padding:"3px 10px",borderRadius:6,background:"rgba(245,158,11,0.15)",color:"#f59e0b",fontSize:12}}>{g}</span>)}</div>}
          <table style={{width:"100%",borderCollapse:"collapse",fontSize:13,marginBottom:20}}>
            <thead><tr style={{borderBottom:"1px solid rgba(255,255,255,0.08)"}}>{["Grade","Metal Price (AED/kg)",""].map(h=><th key={h} style={s.th}>{h}</th>)}</tr></thead>
            <tbody>{Object.entries(gp).map(([grade,p])=>(
              <tr key={grade} style={{borderBottom:"1px solid rgba(255,255,255,0.05)"}}>
                <td style={s.td}>{grade}{p.estimated&&<span style={{marginLeft:6,fontSize:10,padding:"2px 5px",borderRadius:4,background:"rgba(245,158,11,0.2)",color:"#f59e0b"}}>EST</span>}</td>
                <td style={s.td}><input type="number" value={p.base} step="0.5" onChange={e=>setGp(prev=>({...prev,[grade]:{...prev[grade],base:parseFloat(e.target.value),estimated:false}}))} style={{...s.inp,width:90}}/></td>
                <td style={s.td}><button onClick={()=>{const np={...gp};delete np[grade];setGp(np);setNewGrades(g=>g.filter(x=>x!==grade));}} style={{padding:"3px 10px",background:"rgba(239,68,68,0.1)",border:"1px solid rgba(239,68,68,0.2)",borderRadius:6,color:"#ef4444",fontSize:11,cursor:"pointer"}}>Remove</button></td>
              </tr>
            ))}</tbody>
          </table>
          <div style={{background:"rgba(255,255,255,0.03)",borderRadius:10,padding:14}}>
            <div style={{display:"flex",gap:10,alignItems:"flex-end"}}>
              <div style={{flex:1}}><label style={s.lbl}>Grade Name</label><input value={newGrade.name} onChange={e=>setNewGrade(g=>({...g,name:e.target.value}))} placeholder="e.g. A193 B16" style={s.inp}/></div>
              <div style={{width:130}}><label style={s.lbl}>Metal Price AED/kg</label><input type="number" value={newGrade.base} onChange={e=>setNewGrade(g=>({...g,base:e.target.value}))} placeholder="e.g. 8.5" style={s.inp}/></div>
              <button onClick={addGrade} style={{padding:"8px 20px",background:"linear-gradient(135deg,#3b82f6,#6366f1)",color:"#fff",border:"none",borderRadius:8,fontWeight:700,fontSize:13,cursor:"pointer",whiteSpace:"nowrap"}}>+ Add Grade</button>
            </div>
          </div>
        </div>}

        {/* ── COATINGS ── */}
        {tab==="coatings"&&<div style={s.card}>
          <p style={{fontSize:13,color:"#64748b",marginTop:0}}>Flat-rate coatings use one AED/kg. Diameter-based coatings auto-pick price by bolt size.</p>
          <p style={{fontSize:11,color:"#60a5fa",fontWeight:600,marginBottom:8,textTransform:"uppercase"}}>Flat Rate (AED/kg)</p>
          <table style={{width:"100%",borderCollapse:"collapse",fontSize:13,marginBottom:16}}>
            <thead><tr style={{borderBottom:"1px solid rgba(255,255,255,0.08)"}}>{["Coating","Price (AED/kg)",""].map(h=><th key={h} style={s.th}>{h}</th>)}</tr></thead>
            <tbody>{Object.entries(flat).map(([name,price])=>(
              <tr key={name} style={{borderBottom:"1px solid rgba(255,255,255,0.05)"}}>
                <td style={s.td}>{name}</td>
                <td style={s.td}><input type="number" value={price} step="0.5" onChange={e=>setFlat(c=>({...c,[name]:parseFloat(e.target.value)}))} style={{...s.inp,width:90}}/></td>
                <td style={s.td}><button onClick={()=>{const nc={...flat};delete nc[name];setFlat(nc);}} style={{padding:"3px 10px",background:"rgba(239,68,68,0.1)",border:"1px solid rgba(239,68,68,0.2)",borderRadius:6,color:"#ef4444",fontSize:11,cursor:"pointer"}}>Remove</button></td>
              </tr>
            ))}</tbody>
          </table>
          <p style={{fontSize:11,color:"#a78bfa",fontWeight:600,marginBottom:8,textTransform:"uppercase"}}>Diameter-Based Coatings</p>
          <div style={{overflowX:"auto",marginBottom:16}}>
            <table style={{borderCollapse:"collapse",fontSize:11}}>
              <thead><tr style={{borderBottom:"1px solid rgba(255,255,255,0.08)"}}><th style={{...s.th,minWidth:55}}>Size"</th>{Object.keys(DIAMETER_COATINGS).map(n=><th key={n} style={{...s.th,minWidth:100,color:"#a78bfa"}}>{n}</th>)}</tr></thead>
              <tbody>{DSIZES.map(sz=>(
                <tr key={sz} style={{borderBottom:"1px solid rgba(255,255,255,0.04)"}}>
                  <td style={{...s.td,color:"#60a5fa",fontWeight:600}}>{sz}"</td>
                  {Object.keys(DIAMETER_COATINGS).map(n=><td key={n} style={{...s.td,color:"#34d399"}}>{DIAMETER_COATINGS[n][sz]||"-"}</td>)}
                </tr>
              ))}</tbody>
            </table>
          </div>
          <div style={{background:"rgba(255,255,255,0.03)",borderRadius:10,padding:14}}>
            <div style={{display:"flex",gap:10,alignItems:"flex-end"}}>
              <div style={{flex:1}}><label style={s.lbl}>Coating Name</label><input value={newCoat.name} onChange={e=>setNewCoat(c=>({...c,name:e.target.value}))} placeholder="e.g. HOT DIP GALV" style={s.inp}/></div>
              <div style={{width:130}}><label style={s.lbl}>Price AED/kg</label><input type="number" value={newCoat.price} onChange={e=>setNewCoat(c=>({...c,price:e.target.value}))} placeholder="e.g. 12" style={s.inp}/></div>
              <button onClick={addCoat} style={{padding:"8px 20px",background:"linear-gradient(135deg,#3b82f6,#6366f1)",color:"#fff",border:"none",borderRadius:8,fontWeight:700,fontSize:13,cursor:"pointer",whiteSpace:"nowrap"}}>+ Add</button>
            </div>
          </div>
        </div>}

        {/* ── CERTIFICATIONS ── */}
        {tab==="certifications"&&<div style={s.card}>
          <p style={{fontSize:13,color:"#64748b",marginTop:0}}>% markup added to items subtotal.</p>
          <table style={{width:"100%",borderCollapse:"collapse",fontSize:13,marginBottom:20}}>
            <thead><tr style={{borderBottom:"1px solid rgba(255,255,255,0.08)"}}>{["Certification","% Markup","Description",""].map(h=><th key={h} style={s.th}>{h}</th>)}</tr></thead>
            <tbody>{Object.entries(certs).map(([name,c])=>(
              <tr key={name} style={{borderBottom:"1px solid rgba(255,255,255,0.05)"}}>
                <td style={{...s.td,fontWeight:600}}>{name}</td>
                <td style={s.td}><input type="number" value={c.pct} step="0.5" onChange={e=>setCerts(prev=>({...prev,[name]:{...prev[name],pct:parseFloat(e.target.value)||0}}))} style={{...s.inp,width:70}}/></td>
                <td style={s.td}><input value={c.desc} onChange={e=>setCerts(prev=>({...prev,[name]:{...prev[name],desc:e.target.value}}))} style={{...s.inp,width:260}}/></td>
                <td style={s.td}>{name!=="None"&&<button onClick={()=>{const nc={...certs};delete nc[name];setCerts(nc);}} style={{padding:"3px 10px",background:"rgba(239,68,68,0.1)",border:"1px solid rgba(239,68,68,0.2)",borderRadius:6,color:"#ef4444",fontSize:11,cursor:"pointer"}}>Remove</button>}</td>
              </tr>
            ))}</tbody>
          </table>
          <div style={{background:"rgba(255,255,255,0.03)",borderRadius:10,padding:14}}>
            <div style={{display:"flex",gap:10,alignItems:"flex-end",flexWrap:"wrap"}}>
              <div style={{flex:1,minWidth:140}}><label style={s.lbl}>Cert Name</label><input value={newCert.name} onChange={e=>setNewCert(c=>({...c,name:e.target.value}))} placeholder="e.g. NACE MR-01-75" style={s.inp}/></div>
              <div style={{width:100}}><label style={s.lbl}>% Markup</label><input type="number" value={newCert.pct} onChange={e=>setNewCert(c=>({...c,pct:e.target.value}))} placeholder="e.g. 5" style={s.inp}/></div>
              <div style={{flex:2,minWidth:180}}><label style={s.lbl}>Description</label><input value={newCert.desc} onChange={e=>setNewCert(c=>({...c,desc:e.target.value}))} placeholder="Brief description" style={s.inp}/></div>
              <button onClick={addCert} style={{padding:"8px 20px",background:"linear-gradient(135deg,#6366f1,#818cf8)",color:"#fff",border:"none",borderRadius:8,fontWeight:700,fontSize:13,cursor:"pointer",whiteSpace:"nowrap"}}>+ Add</button>
            </div>
          </div>
        </div>}

        {/* ── COMPETITION ── */}
        {tab==="competition"&&<div style={s.card}>
          <p style={{fontSize:13,color:"#64748b",marginTop:0}}>Each level applies a % discount to the grand total.</p>
          <div style={{display:"grid",gridTemplateColumns:"repeat(auto-fit,minmax(260px,1fr))",gap:14,marginBottom:20}}>
            {Object.entries(competition).map(([key,c])=>(
              <div key={key} style={{background:"rgba(255,255,255,0.03)",border:comp===key?"1px solid rgba(248,113,113,0.4)":"1px solid rgba(255,255,255,0.08)",borderRadius:12,padding:16}}>
                <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:12}}>
                  <span style={{fontWeight:800,fontSize:20,color:comp===key?"#f87171":"#e2e8f0"}}>Level {key}</span>
                  <span style={{fontSize:11,padding:"3px 10px",borderRadius:6,background:comp===key?"rgba(248,113,113,0.2)":"rgba(255,255,255,0.06)",color:comp===key?"#f87171":"#64748b",fontWeight:600}}>{comp===key?"ACTIVE":"inactive"}</span>
                </div>
                <div style={{marginBottom:10}}><label style={s.lbl}>Label</label><input value={c.label} onChange={e=>setCompetition(p=>({...p,[key]:{...p[key],label:e.target.value}}))} style={s.inp}/></div>
                <div style={{marginBottom:14}}><label style={s.lbl}>Price Reduction (%)</label>
                  <div style={{display:"flex",alignItems:"center",gap:10}}>
                    <input type="number" min="0" max="50" value={c.pct} onChange={e=>setCompetition(p=>({...p,[key]:{...p[key],pct:parseFloat(e.target.value)||0}}))} style={{...s.inp,width:80}}/>
                    <span style={{fontSize:13,color:"#f87171",fontWeight:700}}>-{c.pct}% off</span>
                  </div>
                </div>
                <button onClick={()=>setComp(key)} style={{width:"100%",padding:"9px",background:comp===key?"rgba(248,113,113,0.2)":"rgba(255,255,255,0.06)",border:comp===key?"1px solid rgba(248,113,113,0.4)":"1px solid rgba(255,255,255,0.1)",borderRadius:8,color:comp===key?"#f87171":"#94a3b8",fontWeight:700,fontSize:13,cursor:"pointer"}}>{comp===key?"✓ Selected":"Select Level "+key}</button>
              </div>
            ))}
          </div>
          <div style={{padding:"14px 16px",background:"rgba(248,113,113,0.06)",border:"1px solid rgba(248,113,113,0.15)",borderRadius:10}}>
            <p style={{margin:0,fontSize:12,color:"#94a3b8"}}>Active: <span style={{color:"#f87171",fontWeight:700}}>Level {comp} — {competition[comp].label}</span> | Reduction: <span style={{color:"#f87171",fontWeight:700}}>-{competition[comp].pct}%</span></p>
          </div>
        </div>}

        {/* ── URGENCY TABLE ── */}
        {tab==="urgency"&&<div style={s.card}>
          <p style={{fontSize:13,color:"#64748b",marginTop:0}}>Urgency markup % by weight range and delivery days.</p>
          <div style={{overflowX:"auto"}}>
            <table style={{width:"100%",borderCollapse:"collapse",fontSize:13}}>
              <thead><tr style={{borderBottom:"1px solid rgba(255,255,255,0.1)"}}>
                <th style={{...s.th,minWidth:140}}>Weight Range</th>
                {URGENCY_DLABELS.map(d=><th key={d} style={{...s.th,textAlign:"center",minWidth:80}}>{d}</th>)}
              </tr></thead>
              <tbody>{urgency.map((row,ri)=>(
                <tr key={ri} style={{borderBottom:"1px solid rgba(255,255,255,0.05)",background:ri%2===0?"transparent":"rgba(255,255,255,0.02)"}}>
                  <td style={{...s.td,color:"#60a5fa",fontWeight:600}}>{row.label}</td>
                  {row.cols.map((val,ci)=>(
                    <td key={ci} style={{...s.td,textAlign:"center"}}>
                      <div style={{display:"flex",alignItems:"center",justifyContent:"center",gap:2}}>
                        <input type="number" min="0" max="100" value={val} onChange={e=>setUrgency(t=>t.map((r,i)=>i===ri?{...r,cols:r.cols.map((c,j)=>j===ci?parseFloat(e.target.value)||0:c)}:r))} style={{...s.inp,width:50,textAlign:"center",padding:"4px 6px",color:"#f59e0b",fontWeight:700}}/>
                        <span style={{color:"#64748b",fontSize:10}}>%</span>
                      </div>
                    </td>
                  ))}
                </tr>
              ))}</tbody>
            </table>
          </div>
          <button onClick={()=>setUrgency(URGENCY_DEFAULT)} style={{marginTop:12,padding:"7px 18px",background:"rgba(239,68,68,0.1)",border:"1px solid rgba(239,68,68,0.2)",borderRadius:8,color:"#ef4444",fontSize:12,cursor:"pointer",fontWeight:600}}>Reset to Defaults</button>
        </div>}

        {/* ── DELIVERY ── */}
        {tab==="delivery"&&<div>
          <p style={{fontSize:13,color:"#64748b",margin:"0 0 16px"}}>Delivery rates (AED) per destination with weight tiers.</p>
          {Object.entries(delivery).map(([grp,dests])=>(
            <div key={grp} style={{...s.card,marginBottom:16}}>
              <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",cursor:"pointer",marginBottom:exGrp===grp?12:0}} onClick={()=>setExGrp(exGrp===grp?null:grp)}>
                <span style={{fontWeight:700,fontSize:14,color:"#60a5fa"}}>{grp}</span>
                <span style={{color:"#64748b",fontSize:18}}>{exGrp===grp?"▲":"▼"}</span>
              </div>
              {exGrp===grp&&Object.entries(dests).map(([d,tiers])=>(
                <div key={d} style={{marginBottom:14,padding:"12px 14px",background:"rgba(255,255,255,0.03)",borderRadius:10,border:"1px solid rgba(255,255,255,0.06)"}}>
                  <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:10}}>
                    <span style={{fontWeight:600,fontSize:13}}>{d}</span>
                    <button onClick={()=>remDest(grp,d)} style={{padding:"3px 10px",background:"rgba(239,68,68,0.1)",border:"1px solid rgba(239,68,68,0.2)",borderRadius:6,color:"#ef4444",fontSize:11,cursor:"pointer"}}>Remove</button>
                  </div>
                  <table style={{width:"100%",borderCollapse:"collapse",fontSize:12}}>
                    <thead><tr style={{borderBottom:"1px solid rgba(255,255,255,0.06)"}}><th style={s.th}>Up to kg (∞=any)</th><th style={s.th}>Rate (AED)</th><th style={s.th}></th></tr></thead>
                    <tbody>{tiers.map((t,idx)=>(
                      <tr key={idx} style={{borderBottom:"1px solid rgba(255,255,255,0.04)"}}>
                        <td style={s.td}><input value={t.maxKg===Infinity?"∞":t.maxKg} onChange={e=>updTier(grp,d,idx,"maxKg",e.target.value)} style={{...s.inp,width:90}}/></td>
                        <td style={s.td}><input type="number" value={t.rate} onChange={e=>updTier(grp,d,idx,"rate",e.target.value)} style={{...s.inp,width:100}}/></td>
                        <td style={s.td}><button onClick={()=>remTier(grp,d,idx)} style={{padding:"3px 8px",background:"rgba(239,68,68,0.1)",border:"1px solid rgba(239,68,68,0.2)",borderRadius:5,color:"#ef4444",fontSize:11,cursor:"pointer"}}>×</button></td>
                      </tr>
                    ))}</tbody>
                  </table>
                  <button onClick={()=>addTier(grp,d)} style={{marginTop:8,padding:"5px 14px",background:"rgba(52,211,153,0.1)",border:"1px solid rgba(52,211,153,0.2)",borderRadius:6,color:"#34d399",fontSize:12,cursor:"pointer"}}>+ Add Tier</button>
                </div>
              ))}
            </div>
          ))}
          <div style={{...s.card,border:"1px solid rgba(99,102,241,0.3)"}}>
            <p style={{margin:"0 0 12px",fontSize:12,color:"#a78bfa",fontWeight:600,textTransform:"uppercase",letterSpacing:0.8}}>Add New Destination</p>
            <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:10,marginBottom:12}}>
              <div><label style={s.lbl}>Group</label><select value={newDest.group} onChange={e=>setNewDest(d=>({...d,group:e.target.value}))} style={s.sel}>{Object.keys(delivery).map(g=><option key={g}>{g}</option>)}</select></div>
              <div><label style={s.lbl}>Destination Name</label><input value={newDest.name} onChange={e=>setNewDest(d=>({...d,name:e.target.value}))} placeholder="e.g. Muscat" style={s.inp}/></div>
            </div>
            <p style={{fontSize:11,color:"#64748b",margin:"0 0 8px",fontWeight:600,textTransform:"uppercase"}}>Weight Tiers</p>
            {newDest.tiers.map((t,i)=>(
              <div key={i} style={{display:"flex",gap:8,marginBottom:8,alignItems:"center"}}>
                <input value={t.maxKg} onChange={e=>setNewDest(d=>{const ts=[...d.tiers];ts[i]={...ts[i],maxKg:e.target.value};return{...d,tiers:ts};})} placeholder="Max kg (blank=∞)" style={{...s.inp,width:140}}/>
                <input type="number" value={t.rate} onChange={e=>setNewDest(d=>{const ts=[...d.tiers];ts[i]={...ts[i],rate:e.target.value};return{...d,tiers:ts};})} placeholder="Rate AED" style={{...s.inp,width:120}}/>
                {newDest.tiers.length>1&&<button onClick={()=>setNewDest(d=>({...d,tiers:d.tiers.filter((_,j)=>j!==i)}))} style={{padding:"4px 8px",background:"rgba(239,68,68,0.1)",border:"1px solid rgba(239,68,68,0.2)",borderRadius:5,color:"#ef4444",cursor:"pointer"}}>×</button>}
              </div>
            ))}
            <div style={{display:"flex",gap:10,marginTop:4}}>
              <button onClick={()=>setNewDest(d=>({...d,tiers:[...d.tiers,{maxKg:"",rate:""}]}))} style={{padding:"6px 14px",background:"rgba(52,211,153,0.1)",border:"1px solid rgba(52,211,153,0.2)",borderRadius:6,color:"#34d399",fontSize:12,cursor:"pointer"}}>+ Add Tier</button>
              <button onClick={addDest} style={{padding:"8px 20px",background:"linear-gradient(135deg,#3b82f6,#6366f1)",color:"#fff",border:"none",borderRadius:8,fontWeight:700,fontSize:13,cursor:"pointer"}}>+ Add Destination</button>
            </div>
          </div>
        </div>}

        {/* ── HISTORY ── */}
        {tab==="history"&&<div style={s.card}>
          <div style={{display:"flex",gap:8,marginBottom:16}}>
            {[["all","All"],["won","Won"],["lost","Lost"],["pending","Pending"]].map(([k,v])=>(
              <button key={k} onClick={()=>setWonFilter(k)} style={{padding:"6px 14px",borderRadius:7,border:"none",cursor:"pointer",fontSize:12,fontWeight:600,background:wonFilter===k?(k==="won"?"rgba(52,211,153,0.3)":k==="lost"?"rgba(248,113,113,0.3)":"rgba(59,130,246,0.3)"):"rgba(255,255,255,0.06)",color:wonFilter===k?(k==="won"?"#34d399":k==="lost"?"#f87171":"#60a5fa"):"#94a3b8"}}>{v}</button>
            ))}
          </div>
          <table style={{width:"100%",borderCollapse:"collapse",fontSize:13}}>
            <thead><tr style={{borderBottom:"1px solid rgba(255,255,255,0.08)"}}>{["Date","Description","Total AED","Result",""].map(h=><th key={h} style={s.th}>{h}</th>)}</tr></thead>
            <tbody>{fh.map((e,i)=>{
              const hi=history.indexOf(e);
              return(<tr key={i} style={{borderBottom:"1px solid rgba(255,255,255,0.05)"}}>
                <td style={s.td}>{e.date}</td><td style={s.td}>{e.desc}</td>
                <td style={{...s.td,color:"#34d399"}}>AED {e.totalAED&&e.totalAED.toLocaleString()}</td>
                <td style={s.td}><span style={{padding:"3px 10px",borderRadius:6,fontSize:11,fontWeight:600,background:e.won===true?"rgba(52,211,153,0.2)":e.won===false?"rgba(248,113,113,0.2)":"rgba(255,255,255,0.07)",color:e.won===true?"#34d399":e.won===false?"#f87171":"#64748b"}}>{e.won===true?"WON":e.won===false?"LOST":"PENDING"}</span></td>
                <td style={s.td}><div style={{display:"flex",gap:6}}>
                  <button onClick={()=>setHistory(h=>h.map((x,j)=>j===hi?{...x,won:true}:x))} style={{padding:"4px 8px",background:"rgba(52,211,153,0.15)",border:"1px solid rgba(52,211,153,0.3)",borderRadius:6,color:"#34d399",fontSize:11,cursor:"pointer"}}>W</button>
                  <button onClick={()=>setHistory(h=>h.map((x,j)=>j===hi?{...x,won:false}:x))} style={{padding:"4px 8px",background:"rgba(248,113,113,0.15)",border:"1px solid rgba(248,113,113,0.3)",borderRadius:6,color:"#f87171",fontSize:11,cursor:"pointer"}}>L</button>
                </div></td>
              </tr>);
            })}</tbody>
          </table>
        </div>}
      </div>
    </div>
  );
}
