  "A193 B7":"BS4320","SS 316":"SS316","SS 304":"SS304",
};
const NUT_TYPES=["Hex Nut","Hvy Hex Nut","Hex Lock Nut","Hvy Hex Lock Nut"];
const WASHER_TYPES=["Plain Washer BS4320","Plain Washer F436","Spring Washer DIN127"];

function getBoltRate(bt,grade,boltRates,nutRates,washerRates,fallback){
  // Nuts
  if(NUT_TYPES.includes(bt)){
    const gk=NUT_GR_TO_RATE[grade]||grade;
    const gi=nutRates.grades.indexOf(gk);
    if(gi>=0){const v=nutRates.products["Hex Nut"][gi];if(v>0)return v;}
    return fallback;
  }
  // Washers
  if(WASHER_TYPES.includes(bt)){
    const gk=WASHER_GR_TO_RATE[grade]||grade;
    const gi=washerRates.grades.indexOf(gk);
    if(gi>=0){const v=washerRates.products["Washer"][gi];if(v>0)return v;}
    return fallback;
  }
  // Bolts
  const rk=BT_TO_RATE[bt];if(!rk)return fallback;
  const gk=GR_TO_RATE[grade]||grade;
  const gi=boltRates.grades.indexOf(gk);
  if(gi<0||!boltRates.products[rk])return fallback;
  const v=boltRates.products[rk][gi];
  if(v===0)return null;
  if(v>0)return v;
  return fallback;
}
const getBulk=kg=>{let p=0;for(const t of BULK)if(kg>=t.minKg)p=t.pct;return p;};
const toMM=s=>{const d=parseFloat(s)*25.4,r=Math.round(d);if(MM.includes(r))return r;for(const m of MM)if(Math.abs(d-m)<=0.5)return m;return r;};
function interp(tbl,key){
  const k=parseFloat(key),ks=Object.keys(tbl).map(Number).sort((a,b)=>a-b);
  if(tbl[k]!==undefined)return tbl[k];
  for(const e of ks)if(Math.abs(e-k)<0.5)return tbl[e];
  if(k<=ks[0]){const r=(tbl[ks[1]]-tbl[ks[0]])/(ks[1]-ks[0]);return Math.max(0,tbl[ks[0]]+r*(k-ks[0]));}
  if(k>=ks[ks.length-1]){const a=ks[ks.length-2],b=ks[ks.length-1];return tbl[b]+((tbl[b]-tbl[a])/(b-a))*(k-b);}
  for(let i=0;i<ks.length-1;i++)if(k>=ks[i]&&k<=ks[i+1])return tbl[ks[i]]+(tbl[ks[i+1]]-tbl[ks[i]])*(k-ks[i])/(ks[i+1]-ks[i]);
  return 0;
}
function nutLook(iT,mT,s,bt){
  const sk=String(parseFloat(s));if(iT[sk]!==undefined)return iT[sk];
  const mm=toMM(s);if(bt&&EN[bt]&&EN[bt][mm]!==undefined)return EN[bt][mm];
  if(mT[mm]!==undefined)return mT[mm];return parseFloat((interp(mT,mm)||0).toFixed(3));
}
function calcW(bt,si,lm,nuts,wash){
  const s=parseFloat(si),l=parseFloat(lm),n=parseInt(nuts)||2,w=parseInt(wash)||0;
  if(!s)return 0;const d=s*25.4,mm=toMM(s);let wt=0;
  if(bt==="Stud Bolt"){
    const t=SB[String(s)];
    if(t&&l)wt=parseFloat((interp(t,l)||0).toFixed(3));
    else if(l){const af=1.5*d,nh=0.875*d;wt=(Math.PI/4)*d*d*l*7.85e-6+2*((Math.sqrt(3)/2*af*af)-(Math.PI/4*d*d))*nh*7.85e-6;}
    const af=1.5*d,nh=(NHI[s]||0.875*s)*25.4,sn=((Math.sqrt(3)/2*af*af)-(Math.PI/4*d*d))*nh*7.85e-6;
    if(n!==2)wt+=(n-2)*sn;
  }else if(bt==="Full Threaded Stud"){
    const ti=FTS_IN[String(s)],tm=FTS_MM[mm];
    if(ti&&l){const v=interp(ti,l);if(v)wt=parseFloat(v.toFixed(3));}
    if(!wt&&tm&&l){const v=interp(tm,l);if(v)wt=parseFloat(v.toFixed(3));}
    if(!wt&&l)for(const k of Object.keys(FTS_MM))if(Math.abs(parseInt(k)-mm)<=1){const v=interp(FTS_MM[k],l);if(v){wt=parseFloat(v.toFixed(3));break;}}
  }else if(bt==="Hex Bolt"){const t=HB[String(s)];wt=(t&&l)?parseFloat((interp(t,l)||0).toFixed(3)):0;
  }else if(bt==="Hvy Hex Bolt"){const t=HHB[String(s)];wt=(t&&l)?parseFloat((interp(t,l)||0).toFixed(3)):0;
  }else if(bt==="Hex Screw"){const t=HS[String(s)];wt=(t&&l)?parseFloat((interp(t,l)||0).toFixed(3)):0;
  }else if(bt==="Hvy Hex Screw"){const t=HHS[String(s)];wt=(t&&l)?parseFloat((interp(t,l)||0).toFixed(3)):0;
  }else if(bt==="Socket Head Cap Screw"){
    const ti=SHCS[String(s)],tm=SHCS_MM[mm];
    if(ti&&l){const v=interp(ti,l);if(v)wt=parseFloat(v.toFixed(3));}
    if(!wt&&tm&&l){const v=interp(tm,l);if(v)wt=parseFloat(v.toFixed(3));}
    if(!wt&&l)for(const k of Object.keys(SHCS_MM))if(Math.abs(parseInt(k)-mm)<=1){const v=interp(SHCS_MM[k],l);if(v){wt=parseFloat(v.toFixed(3));break;}}
  }else if(bt==="Grub Screw"){
    let tm=GRUB[mm];if(!tm)for(const k of Object.keys(GRUB))if(Math.abs(parseInt(k)-mm)<=1){tm=GRUB[k];break;}
    if(tm&&l)wt=parseFloat((interp(tm,l)||0).toFixed(3));
  }else if(bt==="U Bolt"){const t=UB[String(s)];if(t&&l)wt=parseFloat((interp(t,l)||0).toFixed(3));
  }else if(bt==="Hex Nut"){wt=nutLook(HN_IN,HN_MM,s,"Hex Nut");
  }else if(bt==="Hvy Hex Nut"){wt=nutLook(HHN_IN,HHN_MM,s,"Hvy Hex Nut");
  }else if(bt==="Hex Lock Nut"){wt=nutLook(HLN_IN,HLN_MM,s,"Hex Lock Nut");
  }else if(bt==="Hvy Hex Lock Nut"){wt=nutLook(HHLN_IN,HHLN_MM,s,"Hvy Hex Lock Nut");
  }else if(bt==="Plain Washer BS4320"){wt=nutLook(PW_IN,PW_MM,s,"Plain Washer BS4320");
  }else if(bt==="Plain Washer F436"){wt=nutLook({},PW2_MM,s,"Plain Washer F436");
  }else if(bt==="Spring Washer DIN127"){wt=nutLook({},SW_MM,s,"Spring Washer DIN127");}
  if(!NUT_WASHER.includes(bt)&&w>0)wt+=w*nutLook(PW_IN,PW_MM,s,"Plain Washer BS4320");
  return parseFloat(wt.toFixed(3));
}
function getCoatPrice(name,sz,flat){
  if(flat[name]!==undefined)return flat[name];
  const tbl=DIAMETER_COATINGS[name];if(!tbl)return 20;
  const sk=String(parseFloat(sz));if(tbl[sk]!==undefined)return tbl[sk];
  const ks=Object.keys(tbl).map(Number).sort((a,b)=>a-b);const s=parseFloat(sz);
  if(s<=ks[0])return tbl[String(ks[0])];if(s>=ks[ks.length-1])return tbl[String(ks[ks.length-1])];
  for(let i=0;i<ks.length-1;i++)if(s>=ks[i]&&s<=ks[i+1]){const t=(s-ks[i])/(ks[i+1]-ks[i]);return parseFloat((tbl[String(ks[i])]+t*(tbl[String(ks[i+1])]-tbl[String(ks[i])])).toFixed(3));}
  return 20;
}
const getDelRate=(tiers,kg)=>{for(const t of tiers)if(kg<=t.maxKg)return t.rate;return tiers[tiers.length-1].rate;};
const getUrgPct=(kg,days,tbl)=>{const row=tbl.find(r=>kg<=r.maxKg)||tbl[tbl.length-1];for(let i=0;i<URGENCY_DAYS.length;i++)if(days<=URGENCY_DAYS[i])return row.cols[i];return row.cols[row.cols.length-1];};
const getCompP=(si,lm)=>{const t=CT[String(parseFloat(si))];if(!t)return null;const v=interp(t,parseFloat(lm));return v?parseFloat(v.toFixed(2)):null;};
function processRows(rows,inco,pay,gp,flat,boltRates,nutRates,washerRates){
